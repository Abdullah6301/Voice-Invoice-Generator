# Invoice Generator Environment Configuration
# ======================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Application Settings
APP_NAME=Invoice Generator
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here

# Database Settings
SQLITE_DB_PATH=database/invoice_generator.db
# PostgreSQL (cloud-ready, uncomment when needed)
# POSTGRES_URL=postgresql://user:password@localhost:5432/invoice_generator

# AI / NLP Settings
# Speech-to-Text Engine: "vosk" (offline) or "whisper_api" (online)
STT_ENGINE=vosk
# Whisper API Key (only needed if STT_ENGINE=whisper_api)
# OPENAI_API_KEY=your-openai-api-key-here

# Groq API Key (required for AI-powered parsing)
# Get your free key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Vosk Model Path (offline speech recognition)
VOSK_MODEL_PATH=ai_engine/models/vosk-model-small-en-us-0.15

# Server Settings
API_HOST=0.0.0.0
API_PORT=8000
